# --- Android / Gradle (regenerable) ---
.gradle/
build/
local.properties
.externalNativeBuild
.cxx
.kotlin/
*.iml
captures/

# --- IDE local ---
.idea/
.fastRequest/

# --- Cursor / VS Code (rutas personales; sí se publica extensions.json) ---
.vscode/*
!.vscode/extensions.json

# --- APKs y binarios compilados (generar con ./gradlew buildAllApks) ---
*.apk
*.aab
*.dex
output-apks/

# --- PlatformIO (regenerable con pio run) ---
.pio/

# --- Secretos de firma ---
release.keystore
*.keystore

# --- Dependencias npm del generador PDF (docs/npm install) ---
docs/node_modules/
docs/_preview_entrega.html
docs/_pdf_build_temp.*

# --- Clones vendor muy pesados (opcional en local) ---
espessif/

# --- Carpetas de entrega antiguas / artefactos sueltos ---
ENTREGA_FINAL_CIM_V6/
DOCUMENTACION_FINAL/
CIM_V6_*.zip

# --- Sistema operativo ---
.DS_Store
Thumbs.db

# --- Logs temporales ---
*.log
